Cell[CellGroupData[{

Cell["\<\
Shared Helpers: extract per-couplet data from a JSON association\
\>", "Subsubsection",
 CellChangeTimes->{
  3.9819582223477974`*^9, 3.9819714645845814`*^9, {3.9819717693033123`*^9, 
   3.981971776558567*^9}, {3.9820657994513683`*^9, 
   3.9820657999657364`*^9}},ExpressionUUID->"705be0f6-cedc-764d-a6fc-\
e6180381197e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Extract", " ", 
    RowBox[{"{", 
     RowBox[{
     "id", ",", " ", "target", ",", " ", "baseline_word", ",", " ", 
      "baseline_ok", ",", " ", "recurrent_word", ",", " ", "recurrent_ok", ",",
       " ", "result"}], "}"}], "\n", "   ", "from", " ", "the", 
    " ", "\"\<couplets\>\"", " ", "array", " ", "in", " ", "a", " ", "JSON", " ", 
    RowBox[{"association", "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"extractCouplets", "[", "d_", "]"}], " ", ":=", " ", 
     RowBox[{"d", "[", "\"\<couplets\>\"", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
      "Build", " ", "the", " ", "grid", " ", "and", " ", "word", " ", 
       "arrays", " ", "from", " ", "one", " ", "or", " ", "two", " ", "JSON", 
       " ", 
       RowBox[{"runs", ".", "\n", "   ", "Each"}], " ", "JSON", " ", "has", " ",
        "baseline"}], " ", "+", " ", 
      RowBox[{"one", " ", "recurrent", " ", 
       RowBox[{"condition", ".", "\n", "   ", "We"}], " ", "merge", " ", 
       "them", " ", "into", " ", "a", " ", "unified", " ", 
       RowBox[{"grid", ":", "\n", "     ", 
        RowBox[{"col", " ", "1"}]}]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"baseline", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"from", " ", "prefill", " ", "JSON"}], " ", "\[LongDash]", 
         " ", 
         RowBox[{
         "both", " ", "share", " ", "the", " ", "same", " ", "baseline"}]}], 
        ")"}], "\n", "     ", "col", " ", "2"}], " ", "=", " ", 
      RowBox[{
       RowBox[{"prefill", " ", "recurrent", "\n", "     ", "col", " ", "3"}], 
       " ", "=", " ", 
       RowBox[{"sustained", " ", "recurrent"}]}]}]}], " ", "*)"}], 
   "\n"}]}]], "Input",
 CellChangeTimes->{{3.982065797731489*^9, 
  3.982065803954874*^9}},ExpressionUUID->"68f55570-c6be-ad44-b82d-\
49caf64d7ea2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Build Data Tables", "Subsubsection",
 CellChangeTimes->{{3.9820658108816032`*^9, 
  3.982065814330353*^9}},ExpressionUUID->"be69319e-5904-0144-a519-\
8f07339f16b4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"hasPrefill", " ", "&&", " ", "hasSustained"}], ",", "\n", "  ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", " ", "Both"}]}], " ", "files", " ", 
     RowBox[{"available", ":", " ", 
      RowBox[{"3", "-", 
       RowBox[{"column", " ", 
        RowBox[{"grid", " ", "--"}]}], "-"}]}]}], " ", "*)"}], "\n", "  ", 
   RowBox[{
    RowBox[{"pfCouplets", " ", "=", " ", 
     RowBox[{"prefillData", "[", "\"\<couplets\>\"", "]"}]}], ";", "\n", "  ", 
    RowBox[{"susCouplets", " ", "=", " ", 
     RowBox[{"sustainedData", "[", "\"\<couplets\>\"", "]"}]}], ";", "\n", 
    "  ", 
    RowBox[{"nCouplets", " ", "=", " ", 
     RowBox[{"Length", "[", "pfCouplets", "]"}]}], ";", "\n", "\n", "  ", 
    RowBox[{"modelId", " ", "=", " ", 
     RowBox[{"prefillData", "[", "\"\<model_id\>\"", "]"}]}], ";", "\n", "  ", 
    RowBox[{"nLayers", " ", "=", " ", 
     RowBox[{"prefillData", "[", "\"\<n_layers\>\"", "]"}]}], ";", "\n", "\n",
     "  ", 
    RowBox[{"coupletGrid", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"{", "\n", "      ", 
        RowBox[{
         RowBox[{"pfCouplets", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", " ", "\"\<id\>\""}], "]"}], "]"}], ",", "\n", 
         "      ", 
         RowBox[{"pfCouplets", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", " ", "\"\<target\>\""}], "]"}], "]"}], ",", "\n",
          "      ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"pfCouplets", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", " ", "\"\<baseline_rhymes\>\""}], "]"}], "]"}],
            ",", " ", "1", ",", " ", "0"}], "]"}], ",", "\n", "      ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"pfCouplets", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", " ", "\"\<recurrent_rhymes\>\""}], "]"}], 
            "]"}], ",", " ", "1", ",", " ", "0"}], "]"}], ",", "\n", "      ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"susCouplets", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", " ", "\"\<recurrent_rhymes\>\""}], "]"}], 
            "]"}], ",", " ", "1", ",", " ", "0"}], "]"}]}], "\n", "    ", 
        "}"}], ",", "\n", "    ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "nCouplets"}], "}"}]}], "\n", "  ", "]"}]}], ";",
     "\n", "\n", "  ", 
    RowBox[{"generatedWords", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"{", "\n", "      ", 
        RowBox[{
         RowBox[{"pfCouplets", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", " ", "\"\<id\>\""}], "]"}], "]"}], ",", "\n", 
         "      ", 
         RowBox[{"pfCouplets", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", " ", "\"\<baseline_word\>\""}], "]"}], "]"}], ",",
          "\n", "      ", 
         RowBox[{"pfCouplets", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", " ", "\"\<recurrent_word\>\""}], "]"}], "]"}], ",",
          "\n", "      ", 
         RowBox[{"susCouplets", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", " ", "\"\<recurrent_word\>\""}], "]"}], "]"}]}], 
        "\n", "    ", "}"}], ",", "\n", "    ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "nCouplets"}], "}"}]}], "\n", "  ", "]"}]}], ";",
     "\n", "\n", "  ", 
    RowBox[{"conditionLabels", " ", "=", " ", 
     RowBox[{"{", "\n", "    ", 
      RowBox[{"\"\<Baseline\>\"", ",", "\n", "    ", 
       RowBox[{"\"\<Prefill\\nL\>\"", " ", "<>", " ", 
        RowBox[{"ToString", "[", 
         RowBox[{"prefillData", "[", "\"\<loop_start\>\"", "]"}], "]"}], " ", 
        "<>", "\n", "      ", "\"\<\[Dash]\>\"", " ", "<>", " ", 
        RowBox[{"ToString", "[", 
         RowBox[{"prefillData", "[", "\"\<loop_end\>\"", "]"}], "]"}], " ", "<>",
         "\n", "      ", "\"\<, s=\>\"", " ", "<>", " ", 
        RowBox[{"ToString", "[", 
         RowBox[{"prefillData", "[", "\"\<strength\>\"", "]"}], "]"}]}], ",", 
       "\n", "    ", 
       RowBox[{"\"\<Sustained\\nL\>\"", " ", "<>", " ", 
        RowBox[{"ToString", "[", 
         RowBox[{"sustainedData", "[", "\"\<loop_start\>\"", "]"}], "]"}], 
        " ", "<>", "\n", "      ", "\"\<\[Dash]\>\"", " ", "<>", " ", 
        RowBox[{"ToString", "[", 
         RowBox[{"sustainedData", "[", "\"\<loop_end\>\"", "]"}], "]"}], " ", 
        "<>", "\n", "      ", "\"\<, s=\>\"", " ", "<>", " ", 
        RowBox[{"ToString", "[", 
         RowBox[{"sustainedData", "[", "\"\<strength\>\"", "]"}], "]"}]}]}], 
      "\n", "  ", "}"}]}], ";", "\n", "\n", "  ", 
    RowBox[{"conditionRhymes", " ", "=", " ", 
     RowBox[{"{", "\n", "    ", 
      RowBox[{
       RowBox[{"prefillData", "[", "\"\<baseline_rhymes\>\"", "]"}], ",", 
       "\n", "    ", 
       RowBox[{"prefillData", "[", "\"\<recurrent_rhymes\>\"", "]"}], ",", 
       "\n", "    ", 
       RowBox[{"sustainedData", "[", "\"\<recurrent_rhymes\>\"", "]"}]}], 
      "\n", "  ", "}"}]}], ";", "\n", "\n", "  ", 
    RowBox[{"nCols", " ", "=", " ", "3"}], ";", "\n", "  ", 
    RowBox[{"baselineRhymes", " ", "=", " ", 
     RowBox[{"prefillData", "[", "\"\<baseline_rhymes\>\"", "]"}]}]}], ",", 
   "\n", "\n", "  ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", " ", "Only"}]}], " ", "prefill", " ", 
     RowBox[{"available", ":", " ", 
      RowBox[{"2", "-", 
       RowBox[{"column", " ", 
        RowBox[{"grid", " ", "--"}]}], "-"}]}]}], " ", "*)"}], "\n", "  ", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"hasPrefill", " ", "&&", " ", 
      RowBox[{"!", "hasSustained"}]}], ",", "\n", "    ", 
     RowBox[{
      RowBox[{"pfCouplets", " ", "=", " ", 
       RowBox[{"prefillData", "[", "\"\<couplets\>\"", "]"}]}], ";", "\n", 
      "    ", 
      RowBox[{"nCouplets", " ", "=", " ", 
       RowBox[{"Length", "[", "pfCouplets", "]"}]}], ";", "\n", "    ", 
      RowBox[{"modelId", " ", "=", " ", 
       RowBox[{"prefillData", "[", "\"\<model_id\>\"", "]"}]}], ";", "\n", 
      "    ", 
      RowBox[{"nLayers", " ", "=", " ", 
       RowBox[{"prefillData", "[", "\"\<n_layers\>\"", "]"}]}], ";", "\n", 
      "\n", "    ", 
